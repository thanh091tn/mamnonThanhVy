# Copy to .env and adjust. Creates tables automatically on startup.

# Option A — single URL (recommended)
DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/school

# Option B — separate vars (if you omit DATABASE_URL)
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=your_password
# PGDATABASE=school

# Auth (JWT). In production, set a long random JWT_SECRET.
# JWT_SECRET=
# JWT_EXPIRES_IN=7d

# Allow public registration as manager (default: off). Teachers can always register.
# ENABLE_MANAGER_REGISTER=false
